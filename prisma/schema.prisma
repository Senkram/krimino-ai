generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model analiz_sonuclari {
  id                 Int         @id @default(autoincrement())
  supheli_id         Int?
  analiz_turu        String?     @db.VarChar(150)
  guven_skoru        Decimal?    @db.Decimal(4, 2)
  detayli_analiz     Json?
  olusturulma_tarihi DateTime?   @default(now()) @db.Timestamp(6)
  supheliler         supheliler? @relation(fields: [supheli_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_supheli_analiz")
}

model kanitlar {
  id             Int       @id @default(autoincrement())
  olay_id        Int?
  kanit_turu     String?   @db.VarChar(100)
  dosya_yolu     String?
  aciklama       String?
  yukleme_tarihi DateTime? @default(now()) @db.Timestamp(6)
  olaylar        olaylar?  @relation(fields: [olay_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_olay_kanit")
}

model olaylar {
  id                      Int                       @id @default(autoincrement())
  olay_turu               String?                   @db.VarChar(50)
  tarih_saat              DateTime?                 @db.Timestamp(6)
  konum                   String?                   @db.VarChar(50)
  aciklama                String?
  oncelik_seviyesi        String?                   @db.VarChar(20)
  kanitlar                kanitlar[]
  supheli_olay_baglantisi supheli_olay_baglantisi[]
  taniklar                taniklar[]
}

model supheli_olay_baglantisi {
  id         Int         @id @default(autoincrement())
  supheli_id Int?
  olay_id    Int?
  rol        String?     @db.VarChar(50)
  olaylar    olaylar?    @relation(fields: [olay_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_olay")
  supheliler supheliler? @relation(fields: [supheli_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_supheli")
}

model supheliler {
  id                      Int                       @id @default(autoincrement())
  ad                      String                    @db.VarChar(50)
  soyad                   String                    @db.VarChar(50)
  tc_no                   String?                   @db.Char(11)
  dogum_tarihi            DateTime?                 @db.Date
  cinsiyet                String?                   @db.VarChar(10)
  risk_skoru              Decimal?                  @db.Decimal(5, 2)
  profil_ozellikleri      Json?
  analiz_sonuclari        analiz_sonuclari[]
  supheli_olay_baglantisi supheli_olay_baglantisi[]
}

model taniklar {
  id                 Int       @id @default(autoincrement())
  olay_id            Int?
  ad                 String    @db.VarChar(50)
  soyad              String    @db.VarChar(50)
  iletisim_bilgisi   String?   @db.VarChar(255)
  ifade              String?
  guvenilirlik_puani Decimal?  @db.Decimal(3, 2)
  olusturulma_tarihi DateTime? @default(now()) @db.Timestamp(6)
  olaylar            olaylar?  @relation(fields: [olay_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_olay_tanik")
}
